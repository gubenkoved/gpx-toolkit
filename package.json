{
  "name": "beeline-uploader-web",
  "private": true,
  "version": "0.6.1",
  "type": "module",
  "description": "Beeline Toolkit — backend-free, in-browser Beeline cloud companion; upload rides to Strava and more.",
  "scripts": {
    "dev": "vite",
    "dev:proxy": "BEELINE_DEV_PROXY=1 vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "verify": "tsc --noEmit && biome check && vitest run"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.heat": "^0.2.5",
    "@types/node": "^22.10.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
